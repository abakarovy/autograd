# Backend на SQLite — отдельный .env не обязателен.
# Локально файл БД: backend/autograd.db (создаётся сам).
#
# На Vercel backend env не нужен, но запись в SQLite там не сохраняется
# между запросами (serverless). Для админки с правками — запускайте backend локально:
#   cd backend && uvicorn main:app --reload --port 8000
